{
  "manifest_version": 3,
  "name": "Glitch Orchestra",
  "version": "2.0",
  "description": "Networked Ikeda-style sonic performance tool",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Glitch Orchestra"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}